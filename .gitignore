# ============================================================
# .gitignore — Formation Administrateur Réseaux
# ============================================================

# ------------------------------------------------------------
# macOS — IMPORTANT : couvre tous les sous-dossiers
# ------------------------------------------------------------
.DS_Store
.DS_Store?
**/.DS_Store
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon?

# ------------------------------------------------------------
# Windows
# ------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini

# ------------------------------------------------------------
# Éditeurs & IDEs
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------
# Secrets & Identifiants — NE JAMAIS POUSSER
# ------------------------------------------------------------
*.env
*.env.*
.env.local
secrets/
credentials/
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.csr
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# ------------------------------------------------------------
# Logs & fichiers temporaires
# ------------------------------------------------------------
*.log
*.tmp
*.bak
